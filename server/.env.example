# Server port
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# MongoDB connection string
MONGO_URI=

# Redis connection URL
REDIS_URL=redis://localhost:6379

# JWT secrets for signing access and refresh tokens
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# JWT token expiration durations
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Allowed frontend URL for CORS
CLIENT_URL=http://localhost:5173

# AWS credentials for S3 file uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# SendGrid API key for transactional emails
SENDGRID_API_KEY=

# Stripe secret key and webhook signing secret for payment processing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
